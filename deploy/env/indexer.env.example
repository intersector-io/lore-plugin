# @lore/indexer environment. Copy to `env/indexer.env` and fill in every
# REQUIRED value before running the `indexer` compose service
# (`docker compose --profile indexer run indexer rebuild --ref main`, or
# `up -d indexer` in poller mode). Same embedding-provider setting as
# env/api.env.example — they must match or search results won't line up with
# what was indexed.

# --- Database (compose-managed; REQUIRED when running standalone) -------
# postgres://<user>:<password>@<host>:5432/<db>
# LORE_DATABASE_URL=postgres://lore:lore@localhost:55432/lore

# --- Mode selection ---------------------------------------------------
# Unset (default): the container runs whatever one-shot subcommand you pass
# as `docker run`/`compose run` args (rebuild/incremental/status/
# backfill-embeddings/delete-ref/migrate) and exits.
#
# "poll": the container instead runs a long-lived poller that fetches
# LORE_INDEXER_REPO_PATH's `origin/<LORE_INDEXER_REF>` on an interval and
# indexes whatever moved (rebuild on first sight of the ref, incremental
# thereafter) — the alternative to the API's webhook-driven indexing for
# topologies where the git host can't reach this instance directly.
# LORE_INDEXER_MODE=poll

# (compose-managed) Path to the repo checkout to index — the same mount as the
# api service's LORE_REPO_PATH, typically /repo. docker-compose.yml sets it, so
# it needs no value here.
#
# It is the working-tree <path> default for every command that takes one
# (rebuild/incremental/poll), which is why the documented commands pass no
# container path at all: `compose run --rm indexer rebuild --ref main`. Required
# when LORE_INDEXER_MODE=poll; optional (but recommended) otherwise, since a
# one-shot subcommand can always be given an explicit path instead.
# LORE_INDEXER_REPO_PATH=/repo

# Ref to poll. Default: main
# LORE_INDEXER_REF=main

# Poll interval in seconds. Default: 30. Must be a positive number — a
# non-numeric or non-positive value fails the container at boot.
# LORE_INDEXER_POLL_INTERVAL_SECONDS=30

# --- Runtime git config store --------------------------------------------
# In poll mode the indexer reads the SAME runtime config store the API writes
# to resolve the git remote (env LORE_REMOTE_URL wins, else the store file's
# `remoteUrl` — e.g. what the portal setup wizard cloned from); it ensures the
# clone's `origin` from it before the first tick. Point this at the shared
# volume so both containers read one config (compose sets it for you).
# LORE_RUNTIME_CONFIG=/config/runtime-config.json
# LORE_REMOTE_URL=

# --- Embedding provider (optional; default shown) -------------------------
# Must match the api service's LORE_EMBEDDING_PROVIDER — see
# env/api.env.example for the full explanation of both values.
# LORE_EMBEDDING_PROVIDER=fake:default
# LORE_EMBEDDING_DIM=384
# LORE_EMBEDDING_HTTP_URL=
# LORE_EMBEDDING_HTTP_MODEL=
