# @lore/api environment. Copy to `env/api.env` and fill in every REQUIRED
# value before `docker compose up api` — a missing/invalid one fails boot with a
# named error rather than serving. Once the instance is up, the full operator
# reference is served at `/docs/how-to/self-host-lore/`.
#
# Vars marked (compose-managed) are set directly in docker-compose.yml's
# `api` service and don't need a value here; they're listed for completeness
# when running the image outside compose.

# --- Repository (REQUIRED) ---------------------------------------------
# Filesystem path to this instance's clone of the canonical knowledge repo.
# Inside the `api` container this is the compose bind mount's target (/repo);
# see LORE_REPO_HOST_PATH in your shell env / .env for the host-side path.
LORE_REPO_PATH=/repo
# `.lore/` directory name relative to LORE_REPO_PATH. Default: .lore
LORE_DIR=.lore

# --- Auth mode ----------------------------------------------------------
# How principals authenticate: "oidc" (bearer JWTs from the STS below) or
# "local" (built-in username+password; the FIRST registered user is the admin,
# later users are members). Derived when unset: "oidc" if LORE_STS_ISSUER is
# set, else "local". Set explicitly to force one. Local mode needs NO STS vars —
# it mints its own session tokens (accounts + signing secret live 0600 beside
# the runtime config store on the shared volume). Local mode suits a single
# trusted team / trusted network; OIDC is recommended for real organizations.
# LORE_AUTH_MODE=oidc

# --- STS / OIDC (REQUIRED in oidc mode; leave unset for local) -----------
# Your Keycloak (or any OIDC-compliant) realm issuer URL, e.g.
# https://keycloak.example.com/realms/lore — see the "Keycloak wiring" section
# of the operator reference at /docs/how-to/self-host-lore/ for the
# realm/client/audience setup this must match.
LORE_STS_ISSUER=https://keycloak.example.com/realms/lore
# The `aud` claim this API's tokens must carry (the Keycloak client's audience
# mapper target, or a custom `resource` value).
LORE_STS_AUDIENCE=lore-api
# JWKS endpoint. Optional: derived from LORE_STS_ISSUER + Keycloak's default
# path (`<issuer>/protocol/openid-connect/certs`) when unset. Set explicitly
# for non-Keycloak STS implementations.
# LORE_STS_JWKS_URL=
# Path to a local JWKS JSON document ({"keys":[...]})  — an alternative to
# LORE_STS_JWKS_URL for offline/air-gapped deployments or local smoke testing
# with a minted token instead of a reachable STS. Mutually alternative to
# LORE_STS_JWKS_URL: set exactly one.
# LORE_STS_JWKS_FILE=

# --- Database (compose-managed; REQUIRED when running standalone) -------
# postgres://<user>:<password>@<host>:5432/<db>
# DATABASE_URL=postgres://lore:lore@localhost:55432/lore

# --- Runtime git config store --------------------------------------------
# The git stack below (provider, remote, token, webhook secret, service
# identity) is NOT boot-required. It lives in a JSON runtime config store on a
# volume shared with the indexer; the vars below are OPTIONAL seed/override —
# set here, env WINS at boot; unset, the store file supplies them; set in
# neither, the API boots into SETUP MODE (portal + setup endpoints answer, every
# other route returns a named "not configured" error) so an admin can finish git
# setup from the portal. Secrets never touch Postgres and are never returned by
# any GET.
#
# Path to the store file. Defaults to ./.lore-runtime-config.json; compose
# sets it to /config/runtime-config.json on the shared volume.
# LORE_RUNTIME_CONFIG=/config/runtime-config.json

# HMAC secret (GitHub) / static token (GitLab `X-Gitlab-Token`) your git host
# signs `POST /webhooks/git` deliveries with. Its presence is what takes the
# API out of setup mode. Generate with e.g. `openssl rand -hex 32`.
# LORE_WEBHOOK_SECRET=
# Which GitProvider backs webhooks + propose_record's PR/MR lifecycle:
# "github" | "gitlab" | "local" (on-prem, no external git host). Default github.
# LORE_GIT_PROVIDER=github
# Push target for propose_record's draft branches. Defaults to LORE_REPO_PATH
# (this instance's own checkout doubles as the push target) — set explicitly
# for a real GitHub/GitLab remote, e.g. git@github.com:org/repo.git
# LORE_REMOTE_URL=
# Provider-specific repo identifier for the PR/MR API, e.g. "org/repo"
# (GitHub) or "org%2Frepo" / numeric project id (GitLab). Defaults to
# LORE_REMOTE_URL.
# LORE_PROVIDER_REPO=
# Commit author identity for the service's own commits. Defaults shown.
# LORE_GIT_SERVICE_NAME=Lore Bot
# LORE_GIT_SERVICE_EMAIL=lore-bot@localhost
# GitHub REST API auth (propose_record's PR calls). Unset = anonymous,
# rate-limited requests. Also settable via the portal (stored in the runtime
# config file, not here).
# GITHUB_TOKEN=
# GitLab REST API auth + base URL (self-managed instances). Both also
# settable via the portal (stored in the runtime config file, not here).
# GITLAB_TOKEN=
# GITLAB_API_URL=https://gitlab.com/api/v4
# Azure DevOps REST API auth: a PAT with Code: Read & Write. Cloud
# (dev.azure.com) only — Azure DevOps Server / TFS is not supported. The repo is
# "org/project/repo", and there is no API base to configure. NOTE: Azure does not
# sign webhook payloads (HTTP Basic auth is all it offers), so on this provider
# LORE_WEBHOOK_SECRET is a bearer credential — serve /webhooks/git over HTTPS or
# not at all.
# AZURE_DEVOPS_TOKEN=

# --- HTTP server (optional; default shown) -------------------------------
# PORT=3300
# This resource server's own identifier published at
# /.well-known/oauth-protected-resource. Defaults to the request's own origin.
# LORE_API_RESOURCE=

# --- Usage events (optional; default shown) -------------------------------
# JSONL sink path for per-request usage events.
# LORE_USAGE_LOG=usage-events.jsonl

# --- Embedding provider (optional; default shown) -------------------------
# "fake:<seed>" (deterministic, no external calls — fine for on-prem/offline)
# or "http" (POSTs {texts} to LORE_EMBEDDING_HTTP_URL, expects
# {embeddings: number[][]}). Must match the indexer's setting — a mismatch
# reindexes nothing on its own.
# LORE_EMBEDDING_PROVIDER=fake:default
# LORE_EMBEDDING_DIM=384
# LORE_EMBEDDING_HTTP_URL=
# LORE_EMBEDDING_HTTP_MODEL=
